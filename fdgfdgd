-- Функция теста
local function testRemote(name, path, argsList)
    local remote = ReplicatedStorage:FindFirstChild(path)
    if not remote then
        -- Пробуем искать по всем Remotes
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            remote = remotes:FindFirstChild(path)
        end
    end
    if not remote then
        -- Ищем в Events
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events then
            remote = events:FindFirstChild(path)
        end
    end
    if not remote then
        -- Пробуем прямой поиск
        for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
            if obj.Name == path and obj:IsA("RemoteEvent") then
                remote = obj
                break
            end
        end
    end
    
    if not remote then
        return "НЕ НАЙДЕН: " .. path
    end
    
    local char = LocalPlayer.Character
    if not char then return "Нет персонажа" end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return "Нет HRP" end
    
    -- Ищем цель
    local target = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local t = p.Character:FindFirstChild("HumanoidRootPart")
            if t and (t.Position - hrp.Position).Magnitude < 30 then
                target = t
                break
            end
        end
    end
    if not target then target = hrp end
    
    -- Отправляем с разными аргументами
    for _, args in ipairs(argsList) do
        pcall(function()
            remote:FireServer(unpack(args))
        end)
        task.wait(0.05)
    end
    
    return "Вызван: " .. remote:GetFullName()
end

