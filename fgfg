-- Перетаскивание окна
local dragging = false
local dragStart = nil
local startPos = nil

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Настройка перехватов
local function setupHooks()
    -- FireServer
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if (method == "FireServer" or method == "InvokeServer") and recording then
            local remotePath = "?"
            pcall(function() remotePath = self:GetFullName() end)
            local argStr = ""
            for i = 1, math.min(#args, 8) do
                argStr = argStr .. "[" .. i .. "]=" .. safeArg(args[i]) .. " "
            end
            if #args > 8 then argStr = argStr .. "(+" .. (#args - 8) .. " args)" end
            log(method, remotePath .. " " .. argStr)
        end
        
        return oldNamecall(self, ...)
    end
    setreadonly(mt, true)
    
    -- OnClientEvent
    task.spawn(function()
        for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("RemoteEvent") then
                obj.OnClientEvent:Connect(function(...)
                    if not recording then return end
                    local args = {...}
                    if #args > 0 then
                        local argStr = ""
                        for i = 1, math.min(#args, 5) do
                            argStr = argStr .. "[" .. i .. "]=" .. safeArg(args[i]) .. " "
                        end
                        log("OnClientEvent", obj.Name .. " " .. argStr)
                    end
                end)
            end
        end
    end)
    
    -- Character/Tool
    local function hookTool()
        if LocalPlayer.Character then
            for _, obj in pairs(LocalPlayer.Character:GetDescendants()) do
                if obj:IsA("Tool") then
                    log("SYSTEM", "Найден инструмент: " .. obj.Name)
                    obj.Activated:Connect(function()
                        if recording then
                            log("TOOL", obj.Name .. " АКТИВИРОВАН")
                        end
                    end)
                end
            end
        end
    end
    
    LocalPlayer.CharacterAdded:Connect(function()
        wait(0.3)
        hookTool()
    end)
    hookTool()
    
    -- Leaderstats
    local function hookLeaderstats()
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            for _, stat in pairs(ls:GetChildren()) do
                if stat:IsA("IntValue") or stat:IsA("NumberValue") or stat:IsA("StringValue") then
                    log("LEADERSTAT", stat.Name .. " = " .. tostring(stat.Value))
                    stat.Changed:Connect(function(val)
                        if recording then
                            log("STAT.Change", stat.Name .. " -> " .. tostring(val))
                        end
                    end)
                end
            end
        end
    end
    hookLeaderstats()
    LocalPlayer.ChildAdded:Connect(function(c)
        if c.Name == "leaderstats" then wait(0.1); hookLeaderstats() end
    end)
    
    log("SYSTEM", "Все перехваты установлены")
end

