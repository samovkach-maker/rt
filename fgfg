-- Функция логирования в GUI
local function log(cat, msg)
    local t = string.format("%.3f", tick() - startTime)
    local line = "[" .. t .. "][" .. cat .. "] " .. tostring(msg)
    table.insert(logLines, line)
    if #logLines > MAX_LINES then
        table.remove(logLines, 1)
    end
    -- Обновляем текст в GUI
    pcall(function()
        local text = table.concat(logLines, "\n")
        if OutputLabel then
            OutputLabel.Text = text
            -- Автопрокрутка вниз
            OutputLabel.Position = UDim2.new(0, 0, 0, -OutputLabel.TextBounds.Y + OutputLabel.AbsoluteSize.Y)
        end
    end)
end

-- Функция безопасного преобразования аргументов
local function safeArg(arg)
    if arg == nil then return "nil"
    elseif type(arg) == "string" then return '"' .. string.sub(arg, 1, 50) .. '"'
    elseif type(arg) == "number" then return string.format("%.4f", arg)
    elseif type(arg) == "boolean" then return arg and "true" or "false"
    elseif typeof(arg) == "Vector3" then return string.format("V3(%.1f,%.1f,%.1f)", arg.X, arg.Y, arg.Z)
    elseif typeof(arg) == "CFrame" then return string.format("CF(%.1f,%.1f,%.1f)", arg.Position.X, arg.Position.Y, arg.Position.Z)
    elseif typeof(arg) == "Instance" then return arg.ClassName .. ":" .. arg.Name
    elseif type(arg) == "table" then
        local c = 0
        pcall(function() for _ in pairs(arg) do c = c + 1; if c >= 10 then break end end end)
        return "Table(" .. c .. ")"
    elseif type(arg) == "function" then return "func"
    else return tostring(arg):sub(1, 50)
    end
end

