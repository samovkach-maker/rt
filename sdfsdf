                pcall(function() r:FireServer(-1000) end)
                pcall(function() r:FireServer(hrp, -1000) end)
            end
        end
    end},
    {"GeneralHit с отрицательным", function()
        local r = findRemote("GeneralHit")
        if r and LocalPlayer.Character then
