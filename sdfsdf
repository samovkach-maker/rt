-- ТЕСТ ОБХОДА ЛИМИТА 1000 БАУНТИ
-- Запусти когда баунти уже 1000 и не растёт

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local function getBounty()
    -- Баунти висит над головой, пробуем найти через атрибуты
    if LocalPlayer.Character then
        local attr = LocalPlayer.Character:GetAttribute("Bounty")
        if attr then return attr end
        for _, obj in pairs(LocalPlayer.Character:GetDescendants()) do
            if obj:IsA("IntValue") and obj.Name:lower():find("bounty") then
                return obj.Value
            end
        end
    end
    return "?"
end

local function findRemote(name)
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == name and obj:IsA("RemoteEvent") then
            return obj
        end
    end
    return nil
end

