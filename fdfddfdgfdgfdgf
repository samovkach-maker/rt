-- ТЕСТ ИМИТАЦИИ ХИТА: Бьём воздух, себя, без цели
-- Запусти и жми кнопки, смотри на Slaps

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function findGeneralHit()
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == "GeneralHit" and obj:IsA("RemoteEvent") then
            return obj
        end
    end
    return nil
end

local lastSlaps = 0
local generalHit = findGeneralHit()

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "HitSimTest"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 310, 0, 350)
Frame.Position = UDim2.new(0.5, -155, 0.15, 0)
Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Frame.BorderSizePixel = 1
Frame.BorderColor3 = Color3.fromRGB(100, 100, 100)
