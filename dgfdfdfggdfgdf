local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local logLines = {}
local MAX_LINES = 100
local recording = false
local startTime = 0

local function log(cat, msg)
    local t = string.format("%.3f", tick() - startTime)
    local line = "[" .. t .. "][" .. cat .. "] " .. tostring(msg)
    table.insert(logLines, line)
    if #logLines > MAX_LINES then table.remove(logLines, 1) end
    pcall(function()
        OutputLabel.Text = table.concat(logLines, "\n")
    end)
end

-- Расшифровка таблицы ЛЮБЫМ способом
local function decodeTable(tbl, depth)
    depth = depth or 0
    if depth > 6 then return "...(maxdepth)" end
    if type(tbl) ~= "table" then
        return tostring(tbl) .. "<" .. typeof(tbl) .. ">"
    end
    
    local result = ""
    
    -- Способ 1: pairs
    pcall(function()
        for k, v in pairs(tbl) do
            local vs = type(v) == "table" and "{" .. decodeTable(v, depth + 1) .. "}" or tostring(v) .. "<" .. typeof(v) .. ">"
            result = result .. " [" .. tostring(k) .. "]=" .. vs
        end
    end)
    
    -- Способ 2: индексы
    if result == "" then
        pcall(function()
            for i = 1, 20 do
                local v = tbl[i]
                if v == nil then break end
                local vs = type(v) == "table" and "{" .. decodeTable(v, depth + 1) .. "}" or tostring(v) .. "<" .. typeof(v) .. ">"
                result = result .. " [" .. i .. "]=" .. vs
            end
        end)
    end
    
    -- Способ 3: rawget
    if result == "" then
        pcall(function()
            local mt = getmetatable(tbl)
            if mt then
                result = result .. " [metatable]=" .. tostring(mt)
            end
        end)
    end
    
    if result == "" then
        result = " <empty/protected>"
    end
    
    return result
end

-- Слушаем ВСЕ _NETWORK эвенты с полной расшифровкой
for _, obj in pairs(ReplicatedStorage._NETWORK:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        obj.OnClientEvent:Connect(function(...)
            if not recording then return end
            local args = {...}
            log("UUID_EVENT", "=== " .. obj.Name .. " ===")
            for i = 1, #args do
                if type(args[i]) == "table" then
                    log("UUID_EVENT", "Arg[" .. i .. "] TABLE: " .. decodeTable(args[i]))
                else
                    log("UUID_EVENT", "Arg[" .. i .. "]: " .. tostring(args[i]) .. "<" .. typeof(args[i]) .. ">")
                end
            end
        end)
    end
end

-- Слушаем leaderstats
local function hookLeaderstats()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        for _, stat in pairs(ls:GetChildren()) do
            if stat:IsA("IntValue") or stat:IsA("NumberValue") then
                log("STAT", stat.Name .. " = " .. stat.Value)
                stat.Changed:Connect(function(val)
                    if recording then
                        log("STAT", stat.Name .. " -> " .. val .. " (delta: " .. (val - stat.Value) .. ")")
                    end
                end)
            end
        end
    end
end
hookLeaderstats()
LocalPlayer.ChildAdded:Connect(function(c)
    if c.Name == "leaderstats" then wait(0.1); hookLeaderstats() end
end)

