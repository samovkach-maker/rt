-- Получаем текущие Slaps
local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local slaps = ls:FindFirstChild("Slaps")
        if slaps then return slaps.Value end
    end
    return 0
end

-- Функция для OnSwing
local function testOnSwing()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then return "Remotes не найдены" end
    
    local onSwing = remotes:FindFirstChild("OnSwing")
    if not onSwing then return "OnSwing не найден" end
    
    local char = LocalPlayer.Character
    if not char then return "Нет персонажа" end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return "Нет HRP" end
    
    -- Пробуем разные варианты
    pcall(function() onSwing:FireServer() end)
    pcall(function() onSwing:FireServer("Slap") end)
    pcall(function() onSwing:FireServer(hrp) end)
    pcall(function() onSwing:FireServer(hrp.Position) end)
    
    return "Вызван OnSwing"
end

-- Функция для Framework_OnHit
local function testFrameworkOnHit()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then return "Remotes не найдены" end
    
    local onHit = remotes:FindFirstChild("Framework_OnHit")
    if not onHit then return "Framework_OnHit не найден" end
    
    local char = LocalPlayer.Character
    if not char then return "Нет персонажа" end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return "Нет HRP" end
    
    -- Ищем цель
    local target = hrp
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local t = p.Character:FindFirstChild("HumanoidRootPart")
            if t and (t.Position - hrp.Position).Magnitude < 30 then
                target = t
                break
            end
        end
    end
    
    pcall(function() onHit:FireServer(target, 5) end)
    pcall(function() onHit:FireServer(target, "Slap") end)
    pcall(function() onHit:FireServer(target, 1) end)
    pcall(function() onHit:FireServer(LocalPlayer, target, 5) end)
    
    return "Вызван Framework_OnHit"
end

-- Функция для ReplicatedStorage.b
local function testB()
    local b = ReplicatedStorage:FindFirstChild("b")
    if not b then return "b не найден" end
    
    local char = LocalPlayer.Character
    if not char then return "Нет персонажа" end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return "Нет HRP" end
    
    -- Ищем цель
    local target = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local t = p.Character:FindFirstChild("HumanoidRootPart")
            if t and (t.Position - hrp.Position).Magnitude < 30 then
                target = t
                break
            end
        end
    end
    
    if target then
        pcall(function() b:FireServer(target.Position, target) end)
        pcall(function() b:FireServer(target) end)
    end
    pcall(function() b:FireServer(hrp.Position, hrp) end)
    
    return "Вызван b"
end

