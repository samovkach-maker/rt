btn.MouseButton1Click:Connect(function()
    results = "=== УЯЗВИМОСТИ ЧЕРЕЗ ПЕРЧАТКИ ===\n\n"
    results = results .. "Текущая перчатка: " .. getGlove() .. "\n"
    results = results .. "Слапы до: " .. slapsBefore .. "\n\n"
    workingGloves = {}
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    -- 1. Получение всех доступных перчаток
    results = results .. "--- ДОСТУПНЫЕ ПЕРЧАТКИ ---\n"
    
    local gloveFunc = findFunction("CMDRGetGloveIDs")
    if gloveFunc then
        local success, gloves = pcall(function() return gloveFunc:InvokeServer() end)
        if success and gloves then
            results = results .. "Всего перчаток: " .. #gloves .. "\n"
            if #gloves <= 50 then
                for i, g in ipairs(gloves) do
                    results = results .. "  " .. i .. ". " .. tostring(g) .. "\n"
                end
            else
                results = results .. "(слишком много для вывода)\n"
            end
        end
    end
    
    -- 2. Пробуем экипировать разные перчатки
    results = results .. "\n--- ЭКИПИРОВКА ПЕРЧАТОК ---\n"
    
    local equipFuncs = {
        "EquipGlove", "EquipEmote", "SetGloveMasteryEnabled",
        "SpecialGloveAccess", "Framework_UseAbility"
    }
    
    for _, funcName in ipairs(equipFuncs) do
        local r = findRemote(funcName) or findFunction(funcName)
        if r then
            results = results .. funcName .. ": найден\n"
            -- Пробуем экипировать Bounty, Default, и другие
            local testGloves = {"Bounty", "Default", "bounty", "default", "1", 1, "God", "Admin"}
            for _, glove in ipairs(testGloves) do
                pcall(function()
                    if r:IsA("RemoteFunction") then
                        local res = r:InvokeServer(glove)
                        results = results .. "  Invoke(" .. tostring(glove) .. ") = " .. tostring(res) .. "\n"
                    else
                        r:FireServer(glove)
                        results = results .. "  FireServer(" .. tostring(glove) .. ")\n"
                    end
                end)
            end
        else
            results = results .. funcName .. ": не найден\n"
        end
    end
    
    -- 3. Пробуем активировать способности перчаток
    results = results .. "\n--- СПОСОБНОСТИ ПЕРЧАТОК ---\n"
    
    local abilityRemotes = {
        "GeneralAbility", "UseAbility", "Framework_UseAbility",
        "ClientUsedAbility", "RunMasteryAbility", "GlovelMasteryAbility",
        "KillstreakSoulbankAbility", "DefenseMasteryAbility"
    }
    
    for _, name in ipairs(abilityRemotes) do
        local r = findRemote(name)
        if r and hrp then
            results = results .. name .. ": тестирую...\n"
            local before = getSlaps()
            
            for i = 1, 3 do
                pcall(function() r:FireServer(hrp) end)
                task.wait(0.05)
            end
            
            task.wait(0.2)
            local after = getSlaps()
            if after > before then
                results = results .. "  ✅ ДАЛ СЛАПЫ! +" .. (after - before) .. "\n"
                table.insert(workingGloves, name)
            end
        end
    end
    
    -- 4. Пробуем получить перчатки через _NETWORK
    results = results .. "\n--- NETWORK ФУНКЦИИ ---\n"
    
    for _, obj in pairs(ReplicatedStorage._NETWORK:GetDescendants()) do
        if obj:IsA("RemoteFunction") then
            local success, res = pcall(function() return obj:InvokeServer() end)
            if success and res ~= nil then
                local resStr = tostring(res)
                if #resStr < 100 then
                    results = results .. obj.Name .. ": " .. resStr .. "\n"
                end
            end
        end
    end
    
    -- 5. Прямая манипуляция с перчаткой в leaderstats
    results = results .. "\n--- МАНИПУЛЯЦИЯ ПЕРЧАТКОЙ ---\n"
    
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local gloveStat = ls:FindFirstChild("Glove")
        if gloveStat then
            local oldGlove = gloveStat.Value
            -- Пробуем менять на разные перчатки
            local testGloves = {"Overkill", "God", "Admin", "Custom", "Flex", "Default", "Bounty"}
            for _, g in ipairs(testGloves) do
                pcall(function() gloveStat.Value = g end)
                task.wait(0.1)
                local currentGlove = getGlove()
                if currentGlove == g then
                    results = results .. "✅ Можно сменить на: " .. g .. "\n"
                    table.insert(workingGloves, "Смена на " .. g)
                end
            end
            pcall(function() gloveStat.Value = oldGlove end)
        end
    end
    
    -- Итог
    local slapsAfter = getSlaps()
    results = results .. "\n=== ИТОГ ==="
    results = results .. "\nСлапы: " .. slapsBefore .. " → " .. slapsAfter
    if slapsAfter > slapsBefore then
        results = results .. " (+" .. (slapsAfter - slapsBefore) .. ")"
    end
    results = results .. "\nНайдено уязвимостей: " .. #workingGloves
    
    output.Text = results
    setclipboard(results)
    statusLabel.Text = "Готово | Слапы: " .. slapsAfter
end)

