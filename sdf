-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Перебор
local running = false
local testConnection

local function testHitEvent(hitName)
    local hitEvent = ReplicatedStorage:FindFirstChild(hitName)
    if not hitEvent then
        return false
    end
    if not hitEvent:IsA("RemoteEvent") then
        return false
    end
    
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Пробуем разные аргументы
    pcall(function() hitEvent:FireServer(hrp.Position) end)
    pcall(function() hitEvent:FireServer(hrp) end)
    pcall(function() hitEvent:FireServer(LocalPlayer) end)
    pcall(function() hitEvent:FireServer(hrp.Position, 5) end)
    pcall(function() hitEvent:FireServer(5) end)
    
    return true
end

local function startTesting()
    running = true
    local index = 1
    
    testConnection = game:GetService("RunService").Heartbeat:Connect(function()
        -- Не делаем здесь, используем task.spawn
    end)
    
    task.spawn(function()
        while running and index <= #hitEventsList do
            local hitName = hitEventsList[index]
            CurrentLabel.Text = "Текущий: " .. hitName
            ProgressLabel.Text = "Прогресс: " .. index .. "/" .. #hitEventsList
            StatusLabel.Text = "Тестирую " .. hitName .. "... СЛЕДИ ЗА БАУНТИ!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
            
            -- Спамим этот эвент 2 секунды (10 раз с задержкой 0.2)
            for i = 1, 10 do
                if not running then break end
                local found = testHitEvent(hitName)
                if found then
                    StatusLabel.Text = "Спамлю " .. hitName .. " [" .. i .. "/10]"
                end
                task.wait(0.2)
            end
            
            index = index + 1
        end
        
        if index > #hitEventsList then
            StatusLabel.Text = "ПЕРЕБОР ЗАВЕРШЁН! Проверь баунти"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            CurrentLabel.Text = "Текущий: ЗАВЕРШЕНО"
            ProgressLabel.Text = "Прогресс: " .. #hitEventsList .. "/" .. #hitEventsList
        end
    end)
end

local function stopTesting()
    running = false
    if testConnection then
        testConnection:Disconnect()
        testConnection = nil
    end
    StatusLabel.Text = "Остановлено"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    CurrentLabel.Text = "Текущий: СТОП"
end

StartButton.MouseButton1Click:Connect(function()
    if not running then
        startTesting()
    end
end)

StopButton.MouseButton1Click:Connect(function()
    stopTesting()
end)

