-- СКАНЕР СТАРОГО GUI: Вытаскивает все связи кнопок и RemoteEvent из запущенного GUI фарма
-- Сначала запусти старый скрипт чтобы GUI появился, потом этот

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local playerGui = LocalPlayer:WaitForChild("PlayerGui")

local logData = ""

local function log(msg)
    logData = logData .. msg .. "\n"
    print(msg)
end

local function scanGUI()
    logData = ""
    log("========== СКАНИРОВАНИЕ СТАРОГО GUI ==========")
    log("Время: " .. os.date("%H:%M:%S"))
    log("")
    
    for _, gui in pairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            log("GUI НАЙДЕН: " .. gui.Name)
            log("  Детей: " .. #gui:GetChildren())
            
            for _, child in pairs(gui:GetDescendants()) do
                -- Кнопки
                if child:IsA("TextButton") or child:IsA("ImageButton") then
                    log("")
                    log("  КНОПКА: " .. child.Name)
                    log("  Текст: " .. (child:IsA("TextButton") and child.Text or "(image)"))
                    
                    -- Смотрим все соединения
                    local events = {"MouseButton1Click", "MouseButton1Down", "MouseButton1Up", "Activated", "MouseEnter", "MouseLeave"}
                    for _, eventName in ipairs(events) do
                        local conns = getconnections(child[eventName])
                        if #conns > 0 then
                            log("  Событие: " .. eventName .. " (" .. #conns .. " соединений)")
                            for i, conn in ipairs(conns) do
                                local func = conn.Function
                                if func then
                                    -- Пытаемся получить исходный код функции
                                    local info = debug.getinfo(func, "nS")
                                    log("    #" .. i .. " Функция: " .. (info.name or "anonymous"))
                                    log("    Источник: " .. (info.short_src or "?"))
                                    log("    Строка: " .. (info.linedefined or "?"))
                                    
                                    -- Пытаемся декомпилировать функцию
                                    local success, decompiled = pcall(function()
                                        return debug.getupvalues(func)
                                    end)
                                    if success and decompiled then
                                        for j, upval in ipairs(decompiled) do
                                            local valStr
                                            if type(upval) == "function" then
                                                local upInfo = debug.getinfo(upval, "n")
                                                valStr = "function:" .. (upInfo.name or "?")
                                            elseif typeof(upval) == "Instance" then
                                                pcall(function() valStr = upval:GetFullName() end)
                                                if not valStr then valStr = upval.ClassName .. ":" .. upval.Name end
                                            elseif type(upval) == "string" then
                                                valStr = '"' .. upval .. '"'
                                            elseif type(upval) == "number" then
                                                valStr = tostring(upval)
                                            elseif upval == nil then
                                                valStr = "nil"
                                            else
                                                valStr = tostring(upval)
                                            end
                                            log("    Upvalue[" .. j .. "]: " .. valStr)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                
                -- Скрипты
                if child:IsA("LocalScript") or child:IsA("ModuleScript") then
                    log("")
                    log("  СКРИПТ: " .. child.Name .. " [" .. child.ClassName .. "]")
                    log("  ======== КОД ========")
                    pcall(function()
                        log(child.Source)
                    end)
                    log("  =====================")
                end
                
                -- Текстовые поля
                if child:IsA("TextBox") then
                    log("")
                    log("  TEXTBOX: " .. child.Name)
                    log("  Placeholder: " .. child.PlaceholderText)
                    log("  Text: " .. child.Text)
                end
                
                -- Лейблы с важным текстом
                if child:IsA("TextLabel") and child.Text ~= "" then
                    -- Только значимые лейблы
                    if string.find(child.Text, "bounty") or string.find(child.Text, "Bounty") or
                       string.find(child.Text, "баунти") or string.find(child.Text, "фарм") or
                       string.find(child.Text, "farm") or string.find(child.Text, "слап") or
                       string.find(child.Text, "slap") then
                        log("  ЛЕЙБЛ: " .. child.Name .. " = '" .. child.Text .. "'")
                    end
                end
            end
        end
    end
    
    log("")
    log("========== СКАНИРОВАНИЕ ЗАВЕРШЕНО ==========")
    setclipboard(logData)
end

-- GUI для сканирования
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "OldScriptScanner"
ScreenGui.Parent = playerGui

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0, 280, 0, 50)
Button.Position = UDim2.new(0.5, -140, 0.05, 0)
Button.BackgroundColor3 = Color3.fromRGB(200, 120, 0)
Button.Text = "СКАНИРОВАТЬ СТАРЫЙ GUI"
Button.TextColor3 = Color3.fromRGB(255, 255, 255)
Button.Font = Enum.Font.SourceSansBold
Button.TextSize = 16
Button.Parent = ScreenGui

local Status = Instance.new("TextLabel")
Status.Size = UDim2.new(0, 280, 0, 25)
Status.Position = UDim2.new(0.5, -140, 0.05 + 55, 0)
Status.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Status.Text = "Запусти старый GUI и нажми сюда"
Status.TextColor3 = Color3.fromRGB(200, 200, 200)
Status.Font = Enum.Font.SourceSans
Status.TextSize = 12
