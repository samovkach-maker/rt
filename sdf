-- Переменные
local farming = false
local delayTime = 0.5
local hits = 0

-- Функция отправки Hit
local function sendHit()
    local char = LocalPlayer.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Метод 1: Прямой b эвент
    local bEvent = ReplicatedStorage:FindFirstChild("b")
    if bEvent and bEvent:IsA("RemoteEvent") then
        pcall(function()
            bEvent:FireServer(hrp.Position, hrp)
        end)
    end
    
    -- Метод 2: Framework_OnHit
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if remotes then
        local onHit = remotes:FindFirstChild("Framework_OnHit")
        if onHit and onHit:IsA("RemoteEvent") then
            pcall(function()
                -- Цель - любой ближайший игрок или я сам
                local target = hrp
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local tHrp = player.Character:FindFirstChild("HumanoidRootPart")
                        if tHrp and (tHrp.Position - hrp.Position).Magnitude < 50 then
                            target = tHrp
                            break
                        end
                    end
                end
                onHit:FireServer(target, 5)
            end)
        end
    end
    
    -- Метод 3: Все Hit эвенты подряд
    local hitNames = {"DiamondHit", "GhostHit", "GoldenHit", "BombHit", "ReaperHit", 
                      "SnowHit", "FlashHit", "IceHit", "PusherHit", "BrickHit",
                      "GeneralHit", "CustomHit", "ReHit", "SlappleHit"}
    for _, hitName in ipairs(hitNames) do
        local hitEv = ReplicatedStorage:FindFirstChild(hitName)
        if hitEv and hitEv:IsA("RemoteEvent") then
            pcall(function()
                hitEv:FireServer(hrp.Position)
            end)
        end
    end
    
    return true
end

-- Цикл фарма
local farmConnection
local function startFarming()
    farming = true
    farmConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not farming then return end
        -- Используем накопительный счётчик вместо wait()
    end)
    
    -- Отдельный цикл с task.wait
    task.spawn(function()
        while farming do
            local success = sendHit()
            if success then
                hits = hits + 1
                HitCount.Text = "Ударов: " .. hits
            end
            task.wait(delayTime)
        end
    end)
end

local function stopFarming()
    farming = false
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
end

