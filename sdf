local logData = ""
local recording = false
local startTime = 0

local function log(cat, msg)
    local t = string.format("%.4f", tick() - startTime)
    local entry = "[" .. t .. "][" .. cat .. "] " .. tostring(msg)
    logData = logData .. entry .. "\n"
    if #logData > 100000 then
        logData = string.sub(logData, 1, 100000) .. "\n[ОБРЕЗАНО]"
    end
end

-- 1. Перехватываем все InputBegan на всех объектах
local function hookAllInputs()
    -- UserInputService
    local uisConns = getconnections(UserInputService.InputBegan)
    for i, conn in ipairs(uisConns) do
        log("UIS.InputBegan", "Найдено соединение #" .. i)
        pcall(function()
            local func = conn.Function
            if func then
                local info = debug.getinfo(func, "nS")
                log("UIS.InputBegan.Func", "Имя: " .. (info.name or "?") .. " | Источник: " .. (info.short_src or "?"))
            end
        end)
    end
    
    -- GuiService
    local guiConns = getconnections(GuiService.TouchMoved)
    -- Пропускаем, фокус на InputBegan
    
    -- Все кнопки в PlayerGui
    for _, obj in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if obj:IsA("TextButton") or obj:IsA("ImageButton") or obj:IsA("GuiButton") then
            local conns = getconnections(obj.MouseButton1Click)
            if #conns > 0 then
                log("GUI.Button", obj:GetFullName() .. " имеет " .. #conns .. " соединений")
                for i, conn in ipairs(conns) do
                    pcall(function()
                        local func = conn.Function
                        if func then
                            local info = debug.getinfo(func, "nS")
                            log("GUI.Button.Func", obj.Name .. " #" .. i .. " -> " .. (info.name or "?") .. " @ " .. (info.short_src or "?"))
                        end
                    end)
                end
            end
        end
    end
    
    -- ContextActionService
    local boundActions = ContextActionService:GetAllBoundActionInfo()
    for action, info in pairs(boundActions) do
        log("ContextAction", action .. " привязан")
    end
end

-- 2. Перехват FireServer и InvokeServer с полным стеком вызовов
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = function(self, ...)
    local method = getnamecallmethod()
    
    if (method == "FireServer" or method == "InvokeServer") and recording then
        local remotePath = "?"
        pcall(function() remotePath = self:GetFullName() end)
        
        local argStr = ""
        for i = 1, select("#", ...) do
            local arg = select(i, ...)
            local valStr
            if arg == nil then valStr = "nil"
            elseif type(arg) == "string" then valStr = '"' .. arg .. '"'
            elseif type(arg) == "number" then valStr = tostring(arg)
            elseif type(arg) == "boolean" then valStr = arg and "true" or "false"
            elseif typeof(arg) == "Vector3" then valStr = string.format("V3(%.1f,%.1f,%.1f)", arg.X, arg.Y, arg.Z)
            elseif typeof(arg) == "CFrame" then valStr = string.format("CF(%.1f,%.1f,%.1f)", arg.Position.X, arg.Position.Y, arg.Position.Z)
            elseif typeof(arg) == "Instance" then valStr = arg.ClassName .. ":" .. arg.Name
            elseif type(arg) == "table" then
                local c = 0; pcall(function() for _, _ in pairs(arg) do c = c + 1; if c > 5 then break end end end)
                valStr = "Table[" .. c .. "]"
            else valStr = tostring(arg) .. "<" .. typeof(arg) .. ">"
            end
            argStr = argStr .. "[" .. i .. "]=" .. valStr .. " "
        end
        
        log(method, remotePath .. " | " .. argStr)
        
        -- Снимаем стек вызовов
        local trace = debug.traceback("", 2)
        log("STACK", "\n" .. trace)
    end
    
    return oldNamecall(self, ...)
end
setreadonly(mt, true)

-- 3. Перехват OnClientEvent
for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        obj.OnClientEvent:Connect(function(...)
            if not recording then return end
            local args = {...}
            if #args > 0 then
                local argStr = ""
                for i = 1, math.min(#args, 3) do
                    argStr = argStr .. "[" .. i .. "]=" .. tostring(args[i]) .. " "
                end
                log("OnClientEvent", obj.Name .. " | " .. argStr)
            end
        end)
    end
end

