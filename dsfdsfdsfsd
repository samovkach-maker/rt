local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function findRemote(name)
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == name and obj:IsA("RemoteEvent") then
            return obj
        end
    end
    return nil
end

-- Собираем все RemoteEvent, исключаем системные
local function collectRemotes()
    local remotes = {}
    local exclude = {"cmdr", "opera", "badge", "friend", "sidebar", "tournament", "bought", 
                     "gift", "trade", "setting", "daily", "twitter", "crate", "emote", "footstep",
                     "chat", "business", "splat", "music", "radio", "prompt", "vote", "tunnel",
                     "display", "log", "countdown", "check", "popup", "platform", "party",
                     "system", "product", "boost", "spectator", "cube", "shopkeeper", "roguelike",
                     "card", "game", "win", "glove", "elude", "vip", "save", "claim", "reward"}
    
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            local name = obj.Name:lower()
            local skip = false
            for _, ex in ipairs(exclude) do
                if name:find(ex) then skip = true; break end
            end
            if not skip then
                table.insert(remotes, obj)
            end
        end
    end
    return remotes
end

