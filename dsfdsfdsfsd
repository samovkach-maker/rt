-- Тест
local function testSingleRemote(remote)
    local char = LocalPlayer.Character
    if not char then return 0 end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    
    local before = getSlaps()
    
    -- Всего 3 вызова с разными аргументами
    pcall(function() remote:FireServer(hrp) end)
    task.wait(0.1)
    pcall(function() remote:FireServer(hrp.Position) end)
    task.wait(0.1)
    pcall(function() remote:FireServer() end)
    
    task.wait(0.5)
    local after = getSlaps()
    return after - before
end

local function startTest()
    startIndex = tonumber(StartInput.Text) or 1
    if startIndex < 1 then startIndex = 1 end
    if startIndex > #allRemotes then startIndex = #allRemotes end
    
    outputLines = {}
    workingList = {}
    testing = true
    stopped = false
    
    addOutput("=== НАЧАЛО ТЕСТА С ИНДЕКСА " .. startIndex .. " ===")
    addOutput("Всего: " .. #allRemotes .. " | Пауза 3 сек между группами\n")
    
    task.spawn(function()
        local batchSize = 5
        local currentBatch = 0
        
        for i = startIndex, #allRemotes do
            if not testing or stopped then break end
            
            local remote = allRemotes[i]
            local name = remote:GetFullName()
            
            addOutput("[" .. i .. "/" .. #allRemotes .. "] Тест: " .. remote.Name)
            local gained = testSingleRemote(remote)
            
            if gained > 0 then
                addOutput("  ✅ РАБОТАЕТ! +" .. gained .. " Slaps")
                table.insert(workingList, {index = i, name = name, gained = gained})
            end
            
            currentBatch = currentBatch + 1
            
            -- Пауза каждые batchSize эвентов
            if currentBatch >= batchSize then
                currentBatch = 0
                addOutput("  ⏳ Пауза 3 сек... (прогресс: " .. i .. "/" .. #allRemotes .. ")")
                for t = 3, 1, -1 do
                    if not testing or stopped then break end
                    task.wait(1)
                end
            else
                task.wait(0.3)
            end
        end
        
        testing = false
        addOutput("\n=== ЗАВЕРШЕНО ===")
        addOutput("Протестировано: " .. (stopped and "прервано" or "все"))
        addOutput("Найдено рабочих: " .. #workingList)
        
        for i, w in ipairs(workingList) do
            addOutput("  " .. i .. ". " .. w.name .. " (+" .. w.gained .. ")")
        end
        
        InfoLabel.Text = "Завершено. Найдено: " .. #workingList
    end)
end

