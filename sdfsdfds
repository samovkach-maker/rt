-- Обновление списка игроков
local function updatePlayerList()
    local text = "Игроки рядом:\n"
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            text = text .. "• " .. p.Name .. "\n"
        end
    end
    targetLabel.Text = text
end

updatePlayerList()

pickBtn.MouseButton1Click:Connect(function()
    local name = input.Text
    if name == "" or name == "random" then
        -- Случайный игрок
        local list = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(list, p) end
        end
        if #list > 0 then
            targetPlayer = list[math.random(1, #list)]
        end
    else
        targetPlayer = Players:FindFirstChild(name)
    end
    
    if targetPlayer then
        statusLabel.Text = "Цель: " .. targetPlayer.Name
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        statusLabel.Text = "Игрок не найден!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

btn.MouseButton1Click:Connect(function()
    if farming then
        farming = false
        btn.Text = "СТАРТ ЦИКЛ"
        btn.BackgroundColor3 = Color3.fromRGB(30, 150, 30)
        return
    end
    
    if not targetPlayer then
        statusLabel.Text = "Сначала выбери цель!"
        return
    end
    
    farming = true
    kills = 0
    slapsGained = 0
    slapsStart = getSlaps()
    btn.Text = "СТОП"
    btn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
    
    task.spawn(function()
        while farming do
            if not targetPlayer or not targetPlayer.Character then
                statusLabel.Text = "Цель умерла, жду респавна..."
                task.wait(2)
                updatePlayerList()
            end
            
            if targetPlayer and targetPlayer.Character then
                local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHrp then
                    -- Телепорт цели ко мне
                    local myChar = LocalPlayer.Character
                    if myChar then
                        local myHrp = myChar:FindFirstChild("HumanoidRootPart")
                        if myHrp then
                            targetHrp.CFrame = myHrp.CFrame + Vector3.new(0, 5, 0)
                        end
                    end
                    
                    task.wait(0.2)
                    
                    -- Фармим баунти на цели (50 ударов)
                    statusLabel.Text = "Фарм баунти на " .. targetPlayer.Name
                    for i = 1, 50 do
                        if not farming then break end
                        if ga then pcall(function() ga:FireServer(targetHrp) end) end
                        task.wait(0.03)
                        if gh then pcall(function() gh:FireServer(targetHrp) end) end
                        task.wait(0.03)
                    end
                    
                    -- Убиваем цель
                    statusLabel.Text = "Убиваю " .. targetPlayer.Name
                    local hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        hum.Health = 0
                        kills = kills + 1
                    end
                    
                    -- Проверяем слапы
                    local currentSlaps = getSlaps()
                    slapsGained = currentSlaps - slapsStart
                    statsLabel.Text = "Слапы: " .. currentSlaps .. "\nУбийств: " .. kills .. " | +Слапов: " .. slapsGained
                    
                    statusLabel.Text = "Убито! Жду респавна..."
                    task.wait(3)
                end
            end
        end
    end)
end)

-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

