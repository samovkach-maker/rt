local testing = false

btn.MouseButton1Click:Connect(function()
    if testing then return end
    testing = true
    outputLines = {}
    workingList = {}
    addOutput("=== ТЕСТ " .. #combatEvents .. " ЭВЕНТОВ ===\n")
    
    task.spawn(function()
        local char = LocalPlayer.Character
        if not char then addOutput("❌ Нет персонажа!"); testing = false; return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then addOutput("❌ Нет HRP!"); testing = false; return end
        
        for i, name in ipairs(combatEvents) do
            if not testing then break end
            
            local remote = findRemote(name)
            statusLabel.Text = i .. "/" .. #combatEvents .. ": " .. name
            
            if remote then
                -- Бьём 3 раза с разными аргументами
                pcall(function() remote:FireServer(hrp) end)
                task.wait(0.05)
                pcall(function() remote:FireServer(hrp.Position) end)
                task.wait(0.05)
                pcall(function() remote:FireServer() end)
                task.wait(0.05)
                pcall(function() remote:FireServer(0) end)
                
                addOutput("[" .. i .. "] " .. name .. " - протестирован")
                table.insert(workingList, name)
            end
            
            -- Пауза каждые 5 эвентов
            if i % 5 == 0 then
                task.wait(1.5)
            else
                task.wait(0.2)
            end
        end
        
        addOutput("\n=== ГОТОВО ===")
        addOutput("Протестировано: " .. #workingList)
        addOutput("ПРОВЕРЬ БАУНТИ - если выросло, какой-то эвент сработал!")
        addOutput("Смотри логи выше, какой эвент был последним перед ростом")
        statusLabel.Text = "Завершено"
        testing = false
    end)
end)

-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

