local resetCount = 0

local function doHit()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if generalAbility then
        pcall(function() generalAbility:FireServer(hrp) end)
    end
    task.wait(0.04)
    if generalHit then
        pcall(function() generalHit:FireServer(hrp) end)
    end
    
    return true
end

local farmTask
local function startFarm()
    farming = true
    dying = false
    hits = 0
    totalGained = 0
    resetCount = 0
    sessionStartSlaps = getSlaps()
    bountyLimit = tonumber(LimitInput.Text) or 1000
    
    StatusLabel.Text = "Статус: ФАРМ"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    farmTask = task.spawn(function()
        while farming do
            local currentBounty = getBounty()
            local currentSlaps = getSlaps()
            
            -- Проверка: нужно сбросить?
            if currentBounty >= bountyLimit and not dying then
                StatusLabel.Text = "Статус: СБРОС БАУНТИ..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 50)
                ProgressLabel.Text = "Сбрасываю баунти (суицид)..."
                
                resetBounty()
                resetCount = resetCount + 1
                sessionStartSlaps = getSlaps()
                hits = 0
                totalGained = 0
                
                StatusLabel.Text = "Статус: ФАРМ (сброс #" .. resetCount .. ")"
                StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            end
            
            if not dying then
                doHit()
                hits = hits + 1
            end
            
            -- UI
            if hits % 5 == 0 then
                currentBounty = getBounty()
                currentSlaps = getSlaps()
                totalGained = currentSlaps - sessionStartSlaps
                
                SlapsLabel.Text = "Slaps: " .. currentSlaps .. " | Баунти: " .. currentBounty
                ProgressLabel.Text = "Баунти: " .. currentBounty .. "/" .. bountyLimit .. " (сбросов: " .. resetCount .. ")"
                StatsLabel.Text = "Ударов: " .. hits .. " | +Слапов: " .. totalGained
            end
            
            task.wait(delayTime)
        end
    end)
end

local function stopFarm()
    farming = false
    if farmTask then
        task.cancel(farmTask)
        farmTask = nil
    end
    StatusLabel.Text = "Статус: Стоп"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
end

ToggleBtn.MouseButton1Click:Connect(function()
