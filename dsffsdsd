local function findRemote(name)
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == name and obj:IsA("RemoteEvent") then
            return obj
        end
    end
    return nil
end

local generalAbility = findRemote("GeneralAbility")
local generalHit = findRemote("GeneralHit")

local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function getBounty()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        for _, stat in pairs(ls:GetChildren()) do
            if stat.Name:lower():find("bounty") then
                return stat.Value
            end
        end
    end
    return 0
end

local function resetBounty()
    if dying then return end
    dying = true
    
    -- Способ 1: суицид через Health
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            hum.Health = 0
        end
    end
    
    -- Ждём респавна
    task.wait(1)
    
    -- Способ 2: если не умер, пробуем через BreakJoints
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            LocalPlayer.Character:BreakJoints()
        end
    end
    
    -- Ждём возрождения
    local waited = 0
    while not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") do
        task.wait(0.5)
        waited = waited + 0.5
        if waited > 15 then break end
    end
    
    task.wait(1)
    dying = false
end

