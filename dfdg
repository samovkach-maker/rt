local outputLines = {}
local function addOutput(msg)
    table.insert(outputLines, msg)
    if #outputLines > 150 then table.remove(outputLines, 1) end
    OutputLabel.Text = table.concat(outputLines, "\n")
end

-- Кнопки тестов
local tests = {
    {"GeneralAbility (обычный)", function()
        local r = findRemote("GeneralAbility")
        if r and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for i = 1, 5 do
                    pcall(function() r:FireServer(hrp) end)
                    task.wait(0.1)
                end
            end
        end
    end},
    {"GeneralHit (обычный)", function()
        local r = findRemote("GeneralHit")
        if r and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for i = 1, 5 do
                    pcall(function() r:FireServer(hrp) end)
                    task.wait(0.1)
                end
            end
        end
    end},
    {"Удар по ДРУГОМУ игроку", function()
        local r = findRemote("GeneralAbility")
        if r and LocalPlayer.Character then
            local target = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local t = p.Character:FindFirstChild("HumanoidRootPart")
                    if t and (t.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 30 then
                        target = t
                        break
                    end
                end
            end
            if target then
                for i = 1, 5 do
                    pcall(function() r:FireServer(target) end)
                    task.wait(0.1)
                end
            else
                addOutput("Нет игрока рядом")
            end
        end
    end},
    {"BountyResponse (прямой)", function()
        local r = findRemote("BountyResponse")
        if r then
            for i = 1, 5 do
                pcall(function() r:FireServer(5) end)
                pcall(function() r:FireServer("+5") end)
                task.wait(0.1)
            end
        end
    end},
    {"Events.Command /bounty", function()
        local r = findRemote("Command")
        if r then
            pcall(function() r:FireServer("bounty", "5") end)
            pcall(function() r:FireServer("/bounty", "5") end)
            pcall(function() r:FireServer("addbounty", "5") end)
        end
    end},
    {"UseAbility (Remotes)", function()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            local r = remotes:FindFirstChild("UseAbility") or remotes:FindFirstChild("Framework_UseAbility")
            if r then
                for i = 1, 5 do
                    pcall(function() r:FireServer("Slap") end)
                    pcall(function() r:FireServer() end)
                    task.wait(0.1)
                end
            end
        end
    end},
    {"Сброс через смерть", function()
        if LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.Health = 0
                addOutput("Персонаж умер. Жди респавна и проверь баунти.")
            end
        end
    end},
}

local yPos = 330
for _, testData in ipairs(tests) do
    local name = testData[1]
    local func = testData[2]
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(120, 70, 0)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 11
    btn.Parent = Frame
    
    btn.MouseButton1Click:Connect(function()
        local before = getSlaps()
        func()
        task.wait(0.6)
        local after = getSlaps()
        local gained = after - before
        
        InfoLabel.Text = "Slaps: " .. after .. " | Баунти: " .. getBounty()
        
        if gained > 0 then
            addOutput("✅ " .. name .. ": +" .. gained .. " Slaps")
        else
            addOutput("❌ " .. name .. ": 0 Slaps (лимит?)")
        end
    end)
    
    yPos = yPos + 31
end

