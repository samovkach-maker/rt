-- Функции
local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function doHit()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Шаг 1: Замах (OnSwing)
    if onSwing then
        pcall(function() onSwing:FireServer() end)
    end
    if bEvent then
        pcall(function() bEvent:FireServer(hrp.Position, hrp) end)
    end
    
    -- Небольшая пауза как при реальном взмахе
    task.wait(0.05)
    
    -- Шаг 2: Удар (GeneralHit) по себе
    if generalHit then
        -- Пробуем разные варианты
        pcall(function() generalHit:FireServer(hrp) end)
        pcall(function() generalHit:FireServer(hrp.Position) end)
        pcall(function() generalHit:FireServer(LocalPlayer) end)
        pcall(function() generalHit:FireServer(char) end)
        pcall(function() generalHit:FireServer() end)
    end
    
    return true
end

-- Фарм
local farmTask
local function startFarm()
    farming = true
    lastSlaps = getSlaps()
    totalSlapsGained = 0
    hits = 0
    
    farmTask = task.spawn(function()
        while farming do
            doHit()
            hits = hits + 1
            
            -- Проверяем изменение Slaps
            local current = getSlaps()
            if current > lastSlaps then
                totalSlapsGained = totalSlapsGained + (current - lastSlaps)
                lastSlaps = current
            end
            
            -- Обновляем UI
            SlapsLabel.Text = "Slaps: " .. current
            HitsLabel.Text = "Ударов: " .. hits .. " | +Slaps: " .. totalSlapsGained
            SpeedLabel.Text = "Задержка: " .. string.format("%.1f", delayTime) .. "с"
            
            task.wait(delayTime)
        end
    end)
end

local function stopFarm()
    farming = false
    if farmTask then
        task.cancel(farmTask)
        farmTask = nil
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    if farming then
        stopFarm()
        ToggleBtn.Text = "СТАРТ ФАРМ"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(35, 140, 35)
        MethodLabel.Text = "Остановлено | Ударов: " .. hits .. " | +Slaps: " .. totalSlapsGained
    else
        startFarm()
        ToggleBtn.Text = "СТОП ФАРМ"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 35, 35)
    end
end)

