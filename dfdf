local logLines = {}
local MAX_LINES = 300
local recording = false
local startTime = 0

local function log(cat, msg)
    local t = string.format("%.3f", tick() - startTime)
    local line = "[" .. t .. "][" .. cat .. "] " .. tostring(msg)
    table.insert(logLines, line)
    if #logLines > MAX_LINES then table.remove(logLines, 1) end
    pcall(function()
        OutputLabel.Text = table.concat(logLines, "\n")
    end)
end

-- Функция для слежки за объектом и его детьми
local function watchObject(obj, label)
    if not obj then return end
    
    -- Существующие свойства
    pcall(function()
        -- Attributes
        local attrs = obj:GetAttributes()
        for attr, val in pairs(attrs) do
            log("ATTR." .. label, obj.Name .. "." .. attr .. " = " .. tostring(val) .. "<" .. typeof(val) .. ">")
        end
    end)
    
    -- Изменение атрибутов
    obj:GetAttributeChangedSignal(""):Connect(function(attr)
        if recording then
            log("ATTR.CHANGE." .. label, obj.Name .. "." .. attr .. " -> " .. tostring(obj:GetAttribute(attr)))
        end
    end)
    
    -- Изменение parent
    obj.AncestryChanged:Connect(function(child, parent)
        if recording then
            log("ANCESTRY." .. label, obj.Name .. " -> " .. (parent and parent:GetFullName() or "nil"))
        end
    end)
    
    -- Дети
    for _, child in pairs(obj:GetDescendants()) do
        pcall(function()
            if child:IsA("IntValue") or child:IsA("NumberValue") or child:IsA("StringValue") or child:IsA("BoolValue") then
                log("VALUE." .. label, child:GetFullName() .. " = " .. tostring(child.Value))
                child.Changed:Connect(function(val)
                    if recording then
                        log("VALUE.CHANGE." .. label, child:GetFullName() .. " -> " .. tostring(val))
                    end
                end)
            end
            
            if child:IsA("BillboardGui") then
                for _, lbl in pairs(child:GetDescendants()) do
                    if lbl:IsA("TextLabel") then
                        log("BILLBOARD." .. label, lbl:GetFullName() .. " = '" .. lbl.Text .. "'")
                        lbl:GetPropertyChangedSignal("Text"):Connect(function()
                            if recording then
                                log("BILLBOARD.CHANGE." .. label, lbl:GetFullName() .. " -> '" .. lbl.Text .. "'")
                            end
                        end)
                    end
                end
            end
        end)
    end
    
    -- Новые дети
    obj.DescendantAdded:Connect(function(child)
        if recording then
            log("NEW." .. label, child:GetFullName() .. " [" .. child.ClassName .. "]")
            if child:IsA("BillboardGui") then
                wait(0.05)
                for _, lbl in pairs(child:GetDescendants()) do
                    if lbl:IsA("TextLabel") then
                        log("NEW.BILLBOARD." .. label, lbl:GetFullName() .. " = '" .. lbl.Text .. "'")
                    end
                end
            end
        end
    end)
end

-- Следим за персонажем
local function setupCharacterWatch()
    if LocalPlayer.Character then
        log("SYSTEM", "Персонаж: " .. LocalPlayer.Character.Name)
        watchObject(LocalPlayer.Character, "CHAR")
        
        -- Инструменты
        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") then
                log("SYSTEM", "Инструмент в руке: " .. tool.Name)
                watchObject(tool, "TOOL")
            end
        end
    end
end

setupCharacterWatch()
LocalPlayer.CharacterAdded:Connect(function(char)
    log("SYSTEM", "Новый персонаж: " .. char.Name)
    wait(0.3)
    setupCharacterWatch()
end)

-- Инструменты в Backpack
if LocalPlayer.Backpack then
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            log("SYSTEM", "Инструмент в рюкзаке: " .. tool.Name)
            watchObject(tool, "BACKPACK")
        end
    end
end

-- Следим за leaderstats
local function watchLeaderstats()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        for _, stat in pairs(ls:GetChildren()) do
            if stat:IsA("IntValue") or stat:IsA("NumberValue") then
                log("LEADERSTAT", stat.Name .. " = " .. stat.Value)
                stat.Changed:Connect(function(val)
                    if recording then
                        log("LEADERSTAT.CHANGE", stat.Name .. " -> " .. val)
                    end
                end)
            end
        end
    end
end
watchLeaderstats()

