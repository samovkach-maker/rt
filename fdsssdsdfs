local outputLines = {}
local workingList = {}
local testing = false
local stopped = false

local function addOutput(msg)
    table.insert(outputLines, msg)
    if #outputLines > 120 then table.remove(outputLines, 1) end
    OutputLabel.Text = table.concat(outputLines, "\n")
end

BtnStart.MouseButton1Click:Connect(function()
    if testing then return end
    testing = true
    stopped = false
    outputLines = {}
    workingList = {}
    
    addOutput("=== ТЕСТ 50 ЭВЕНТОВ ===\n")
    
    task.spawn(function()
        for i, eventName in ipairs(selectedEvents) do
            if not testing or stopped then break end
            
            local remote = findRemote(eventName)
            ProgressLabel.Text = i .. "/" .. #selectedEvents
            
            if remote then
                local char = LocalPlayer.Character
                if not char then
                    addOutput("❌ Нет персонажа")
                    break
                end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                
                local before = getSlaps()
                
                -- 3 вызова с паузой
                pcall(function() remote:FireServer(hrp) end)
                task.wait(0.15)
                pcall(function() remote:FireServer(hrp.Position) end)
                task.wait(0.15)
                pcall(function() remote:FireServer() end)
                
                task.wait(0.5)
                local after = getSlaps()
                local gained = after - before
                
                if gained > 0 then
                    addOutput("✅ " .. eventName .. ": +" .. gained)
                    table.insert(workingList, eventName)
                    SlapsLabel.Text = "Slaps: " .. after .. " (+" .. gained .. ")"
                end
                
                -- Пауза каждые 3 эвента
                if i % 3 == 0 then
                    addOutput("⏳ пауза 2 сек...")
                    task.wait(2)
                else
                    task.wait(0.3)
                end
            end
        end
        
        testing = false
        addOutput("\n=== ГОТОВО ===")
        addOutput("Рабочих: " .. #workingList)
        for i, name in ipairs(workingList) do
            addOutput("  " .. i .. ". " .. name)
        end
    end)
end)

BtnStop.MouseButton1Click:Connect(function()
