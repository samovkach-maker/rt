testBtn.MouseButton1Click:Connect(function()
    local before = getSlaps()
    local glove = getGlove()
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Тестируем способности
    local remotes = {"GeneralAbility", "GeneralHit", "UseAbility", "Framework_UseAbility"}
    for _, name in ipairs(remotes) do
        local r = findRemote(name)
        if r then
            for i = 1, 5 do
                pcall(function() r:FireServer(hrp) end)
                task.wait(0.05)
            end
        end
    end
    
    task.wait(0.3)
    local after = getSlaps()
    infoLabel.Text = "Перчатка: " .. glove .. " | Слапы: " .. after
    
    if after > before then
        glovesList.Text = "✅ " .. glove .. " ДАЛА СЛАПЫ! +" .. (after - before) .. "\n" .. glovesList.Text
    else
        glovesList.Text = "❌ " .. glove .. " не дала слапов\n" .. glovesList.Text
    end
end)

farmBtn.MouseButton1Click:Connect(function()
    local glove = getGlove()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local ga = findRemote("GeneralAbility")
    local gh = findRemote("GeneralHit")
    
    infoLabel.Text = "Фарм " .. glove + "..."
    
    task.spawn(function()
        for i = 1, 20 do
            if ga then pcall(function() ga:FireServer(hrp) end) end
            task.wait(0.03)
            if gh then pcall(function() gh:FireServer(hrp) end) end
            task.wait(0.05)
        end
        infoLabel.Text = "Перчатка: " .. getGlove() .. " | Слапы: " .. getSlaps()
    end)
end)

-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

