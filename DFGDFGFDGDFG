-- Функция с таймаутом
local function safeInvoke(func, ...)
    local result = nil
    local done = false
    local thread = task.spawn(function()
        pcall(function()
            result = func(...)
        end)
        done = true
    end)
    
    local waited = 0
    while not done and waited < 1 do
        task.wait(0.1)
        waited = waited + 0.1
    end
    
    if not done then
        task.cancel(thread)
        return nil, "timeout"
    end
    
    return result
end

btn.MouseButton1Click:Connect(function()
    if testing then return end
    testing = true
    found = {}
    tested = 0
    skipped = 0
    foundLabel.Text = ""
    
    task.spawn(function()
        for i, obj in ipairs(allRemotes) do
            if not testing then break end
            
            local name = obj.Name
            
            -- Пропускаем проблемные
            local skip = false
            for _, s in ipairs(skipList) do
                if name == s then skip = true; break end
            end
            
            if skip then
                skipped = skipped + 1
                progressLabel.Text = i .. "/" .. #allRemotes .. " | Найдено: " .. #found .. " | Пропущено: " .. skipped
                continue
            end
            
            currentLabel.Text = "#" .. i .. " " .. name
            progressLabel.Text = i .. "/" .. #allRemotes .. " | Найдено: " .. #found .. " | Пропущено: " .. skipped
            
            local before = getSlaps()
            
            if obj:IsA("RemoteEvent") then
                pcall(function() obj:FireServer() end)
                pcall(function() obj:FireServer(LocalPlayer) end)
                pcall(function() obj:FireServer(100) end)
                pcall(function() obj:FireServer("Slaps") end)
                task.wait(0.02)
            elseif obj:IsA("RemoteFunction") then
                -- Вызываем с таймаутом
                safeInvoke(function() return obj:InvokeServer() end)
                task.wait(0.02)
                safeInvoke(function() return obj:InvokeServer(LocalPlayer) end)
                task.wait(0.02)
                safeInvoke(function() return obj:InvokeServer(100) end)
            end
            
            task.wait(0.03)
            local after = getSlaps()
            tested = i
            
            if after > before then
                local msg = "✅ #" .. i .. " " .. name .. " +" .. (after - before)
                table.insert(found, msg)
                foundLabel.Text = foundLabel.Text .. msg .. "\n"
                statusLabel.Text = "НАЙДЕН! " .. name
                statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                setclipboard(foundLabel.Text)
            end
            
            if i % 30 == 0 then
                statusLabel.Text = "Тест " .. i .. "/" .. #allRemotes
                task.wait(0.5)
            end
        end
        
        testing = false
        statusLabel.Text = "Готово! Найдено: " .. #found
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        progressLabel.Text = tested .. "/" .. #allRemotes .. " | Найдено: " .. #found
        currentLabel.Text = ""
    end)
end)

