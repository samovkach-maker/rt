-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- Функция фарма
local function doHit()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Ищем ближайшего игрока
    local target = nil
    local minDist = 20 -- максимум 20 studs
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetHrp = player.Character:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                local dist = (hrp.Position - targetHrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    target = targetHrp
                end
            end
        end
    end
    
    if not target then return false end
    
    local myPos = hrp.CFrame
    local targetPos = target.CFrame
    
    -- Телепорт в цель (внутрь)
    hrp.CFrame = targetPos * CFrame.new(0, 0, -1.5)
    
    -- Задержка для физического контакта
    task.wait(0.05)
    
    -- Телепорт обратно
    hrp.CFrame = myPos
    
    return true
end

-- Цикл фарма
local farmTask
local function startFarm()
    farming = true
    farmTask = task.spawn(function()
        while farming do
            local success = doHit()
            if success then
                hits = hits + 1
                SpeedLabel.Text = "Задержка: " .. string.format("%.1f", delayTime) .. "с | Ударов: " .. hits
            end
            task.wait(delayTime)
        end
    end)
end

local function stopFarm()
    farming = false
    if farmTask then
        task.cancel(farmTask)
        farmTask = nil
    end
end

