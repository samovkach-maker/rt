local function scan()
    exploits = {}
    startTime = tick()
    slapsBefore = getSlaps()
    
    updateResult("🔍 СКАНИРОВАНИЕ НАЧАТО...\n")
    statusLabel.Text = "⏳ Сканирую..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    -- ==================== ТЕСТ 1: СКОРОСТЬ ====================
    progressLabel.Text = "[1/8] Тест скорости..."
    if hum then
        local oldSpeed = hum.WalkSpeed
        hum.WalkSpeed = 200
        task.wait(0.1)
        if hum.WalkSpeed == 200 then
            addExploit("⚡ Изменение скорости", 
                "Ты можешь ходить очень быстро (WalkSpeed = 200)",
                "humanoid.WalkSpeed = 200")
            hum.WalkSpeed = oldSpeed
        end
    end
    
    -- ==================== ТЕСТ 2: ПРЫЖОК ====================
    progressLabel.Text = "[2/8] Тест прыжка..."
    if hum then
        local oldJump = hum.JumpPower
        hum.JumpPower = 300
        task.wait(0.1)
        if hum.JumpPower == 300 then
            addExploit("🦘 Супер-прыжок",
                "Ты можешь прыгать очень высоко (JumpPower = 300)",
                "humanoid.JumpPower = 300")
            hum.JumpPower = oldJump
        end
    end
    
    -- ==================== ТЕСТ 3: ТЕЛЕПОРТ ====================
    progressLabel.Text = "[3/8] Тест телепорта..."
    if hrp then
        local oldPos = hrp.Position
        hrp.CFrame = CFrame.new(0, 100, 0)
        task.wait(0.2)
        local newPos = hrp.Position
        if (newPos - Vector3.new(0, 100, 0)).Magnitude < 10 then
            addExploit("🌀 Свободный телепорт",
                "Ты можешь телепортироваться в любую точку карты",
                "hrp.CFrame = CFrame.new(x, y, z)")
        end
        hrp.CFrame = CFrame.new(oldPos)
    end
    
    -- ==================== ТЕСТ 4: GOD MODE ====================
    progressLabel.Text = "[4/8] Тест годмода..."
    if char then
        local success = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide == true then
                part.CanCollide = false
                success = true
                break
            end
        end
        if success then
            addExploit("🛡️ God Mode (нет коллизии)",
                "Сквозь тебя не могут ударить (CanCollide = false)",
                "part.CanCollide = false для всех частей тела")
        end
    end
    
    -- ==================== ТЕСТ 5: УБИЙСТВО ИГРОКОВ ====================
    progressLabel.Text = "[5/8] Тест убийства игроков..."
    local killed = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then
                h.Health = 0
                killed = killed + 1
            end
        end
    end
    if killed > 0 then
        addExploit("💀 Мгновенное убийство всех игроков",
            "Убил " .. killed .. " игроков (Health = 0)",
            "humanoid.Health = 0 для всех игроков")
    end
    
    -- ==================== ТЕСТ 6: ТЕЛЕПОРТ ИГРОКОВ ====================
    progressLabel.Text = "[6/8] Тест телепорта игроков..."
    if hrp then
        local tped = 0
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local h = p.Character:FindFirstChild("HumanoidRootPart")
                if h then
                    h.CFrame = hrp.CFrame + Vector3.new(0, 5, 0)
                    tped = tped + 1
                end
            end
        end
        if tped > 0 then
            addExploit("📌 Телепорт всех игроков к тебе",
                "Телепортировал " .. tped .. " игроков к себе",
                "player.HumanoidRootPart.CFrame = yourPosition")
        end
    end
    
    -- ==================== ТЕСТ 7: БАУНТИ ФАРМ ====================
    progressLabel.Text = "[7/8] Тест баунти фарма..."
    local ga = findRemote("GeneralAbility")
    local gh = findRemote("GeneralHit")
    if ga and hrp then
        local bountyBefore = getBountyText()
        for i = 1, 5 do
            pcall(function() ga:FireServer(hrp) end)
            if gh then pcall(function() gh:FireServer(hrp) end) end
            task.wait(0.1)
        end
        task.wait(0.3)
        local bountyAfter = getBountyText()
        if bountyBefore ~= bountyAfter then
            addExploit("💰 Фарм баунти (GeneralAbility + GeneralHit)",
                "Даёт +6 баунти за цикл (~400-500/мин)",
                "GeneralAbility:FireServer(hrp) + GeneralHit:FireServer(hrp)")
        end
    end
    
    -- ==================== ТЕСТ 8: СЛАПЫ ====================
    progressLabel.Text = "[8/8] Тест слапов..."
    local slapsAfter = getSlaps()
    if slapsAfter > slapsBefore then
        addExploit("💎 Получены СЛАПЫ!",
            "Слапы увеличились на " .. (slapsAfter - slapsBefore) .. " за время теста",
            "Автоматически при убийстве игроков с баунти")
    end
    
    -- ==================== ВЫДАЧА РЕЗУЛЬТАТОВ ====================
    local result = ""
    
    if #exploits == 0 then
        result = "❌ УЯЗВИМОСТЕЙ НЕ НАЙДЕНО\n\n"
        result = result .. "Сервер хорошо защищён.\n"
        result = result .. "Попробуй на другом сервере или с другой печаткой."
    else
        result = "✅ НАЙДЕНО " .. #exploits .. " УЯЗВИМОСТЕЙ!\n\n"
        result = result .. "Время: " .. string.format("%.1f", tick() - startTime) .. " сек\n"
        result = result .. "Слапы до: " .. slapsBefore .. " | После: " .. slapsAfter .. "\n"
        result = result .. "━━━━━━━━━━━━━━━━━━━━\n\n"
        
        for i, exp in ipairs(exploits) do
            result = result .. i .. ". " .. exp.name .. "\n"
            result = result .. "   📝 " .. exp.desc .. "\n"
            result = result .. "   🔧 " .. exp.how .. "\n\n"
        end
        
        result = result .. "━━━━━━━━━━━━━━━━━━━━\n"
        result = result .. "💡 Используй эти уязвимости для фарма слапов:\n"
        result = result .. "1. Фарми баунти через GeneralAbility\n"
        result = result .. "2. Телепортируй к себе игроков с баунти\n"
        result = result .. "3. Убивай их и забирай слапы\n"
    end
    
    updateResult(result)
    setclipboard(result)
    statusLabel.Text = "✅ Найдено: " .. #exploits
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    progressLabel.Text = "Сканирование завершено!"
    reportLabel.Text = "Скопировано в буфер | Slaps: " .. slapsBefore .. " → " .. slapsAfter
end

