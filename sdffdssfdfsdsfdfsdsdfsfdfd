local slapsBefore = 0

local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function getBountyText()
    if LocalPlayer.Character then
        for _, obj in pairs(LocalPlayer.Character:GetDescendants()) do
            if obj:IsA("BillboardGui") then
                for _, label in pairs(obj:GetDescendants()) do
                    if label:IsA("TextLabel") and label.Text:find("Bounty") then
                        return label.Text
                    end
                end
            end
        end
    end
    return "?"
end

local function findRemote(name)
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == name and obj:IsA("RemoteEvent") then return obj end
    end
    return nil
end

local function addExploit(name, desc, how)
    table.insert(exploits, {name = name, desc = desc, how = how})
end

