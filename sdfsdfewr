    status.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    task.spawn(function()
        while farming do
            local char = LocalPlayer.Character
            if not char then
                status.Text = "Статус: Нет персонажа"
                task.wait(1)
                continue
            end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then
                status.Text = "Статус: Нет HRP"
                task.wait(1)
                continue
            end
            
            -- 5 ударов
            local gained = false
            for i = 1, 5 do
                if not farming then break end
                if ga then pcall(function() ga:FireServer(hrp) end) end
                task.wait(0.04)
                if gh then pcall(function() gh:FireServer(hrp) end) end
                task.wait(0.04)
            end
            
