end

-- Функции
local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function testEvent(remote)
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local beforeSlaps = getSlaps()
    
    -- Пробуем разные комбинации аргументов
    local argSets = {
        {},
        {hrp},
        {hrp.Position},
        {LocalPlayer},
        {char},
        {5},
        {hrp, 5},
        {hrp.Position, 5},
        {LocalPlayer, 5},
        {Vector3.zero},
        {0},
        {1},
    }
    
    for _, args in ipairs(argSets) do
        pcall(function()
            remote:FireServer(unpack(args))
        end)
        task.wait(0.03)
    end
    
    task.wait(0.2)
    local afterSlaps = getSlaps()
    
    return afterSlaps > beforeSlaps, afterSlaps - beforeSlaps
end

-- Собираем все RemoteEvent
local allRemotes = {}
for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        -- Пропускаем системные
        local name = obj.Name:lower()
        if not name:find("cmdr") and not name:find("opera") and not name:find("badge") 
           and not name:find("friend") and not name:find("sidebar") and not name:find("tournament")
           and not name:find("bought") and not name:find("gift") and not name:find("trade")
           and not name:find("setting") and not name:find("daily") and not name:find("twitter")
           and not name:find("crate") and not name:find("emote") and not name:find("footstep")
           and not name:find("chat") and not name:find("business") and not name:find("splat")
           and not name:find("music") and not name:find("radio") and not name:find("prompt")
           and not name:find("vote") and not name:find("tunnel") and not name:find("display")
           and not name:find("log") and not name:find("countdown") then
            table.insert(allRemotes, obj)
        end
    end
end

totalEvents = #allRemotes

-- Тестирование
local function startTesting()
    outputLines = {}
    workingEvents = {}
    testedCount = 0
    testing = true
    
    addOutput("=== НАЧАЛО ТЕСТИРОВАНИЯ " .. totalEvents .. " ЭВЕНТОВ ===")
    addOutput("")
    
    local index = 1
    
    testConnection = RunService.Heartbeat:Connect(function()
        -- Основной цикл через task.spawn
    end)
    
    task.spawn(function()
        while testing and index <= totalEvents do
            local remote = allRemotes[index]
            local remoteName = remote:GetFullName()
            
            testedCount = index
            CurrentLabel.Text = "Текущий: " .. remoteName
            ProgressLabel.Text = "Прогресс: " .. testedCount .. "/" .. totalEvents .. " | Найдено: " .. #workingEvents
            
            local success, gained = testEvent(remote)
            
            if success then
                local msg = "✅ РАБОТАЕТ: " .. remoteName .. " (+" .. gained .. " Slaps)"
                addOutput(msg)
                table.insert(workingEvents, {
                    name = remoteName,
                    path = remote:GetFullName(),
                    gained = gained
                })
                ProgressLabel.Text = "Прогресс: " .. testedCount .. "/" .. totalEvents .. " | Найдено: " .. #workingEvents
            else
                -- Каждые 10 показываем прогресс
                if testedCount % 20 == 0 then
                    addOutput("Тестирую... " .. testedCount .. "/" .. totalEvents .. " | Найдено: " .. #workingEvents)
                end
            end
            
            index = index + 1
            task.wait(0.15) -- Задержка между тестами
        end
        
        -- Завершение
        testing = false
        addOutput("")
        addOutput("=== ТЕСТИРОВАНИЕ ЗАВЕРШЕНО ===")
        addOutput("Протестировано: " .. totalEvents)
        addOutput("Найдено рабочих: " .. #workingEvents)
        addOutput("")
        
        if #workingEvents > 0 then
            addOutput("=== РАБОЧИЕ ЭВЕНТЫ ===")
            for i, ev in ipairs(workingEvents) do
                addOutput(i .. ". " .. ev.name .. " (+" .. ev.gained .. " Slaps)")
            end
        else
            addOutput("Рабочих эвентов не найдено :(")
        end
        
        ProgressLabel.Text = "Прогресс: " .. totalEvents .. "/" .. totalEvents .. " | Найдено: " .. #workingEvents
        CurrentLabel.Text = "Текущий: ЗАВЕРШЕНО"
        StartBtn.BackgroundColor3 = Color3.fromRGB(30, 140, 30)
        StartBtn.Text = "СТАРТ ТЕСТ"
    end)
end

local function stopTesting()
    testing = false
    if testConnection then
        testConnection:Disconnect()
        testConnection = nil
    end
    addOutput("Тест остановлен. Найдено: " .. #workingEvents)
    CurrentLabel.Text = "Текущий: ОСТАНОВЛЕНО"
    StartBtn.BackgroundColor3 = Color3.fromRGB(30, 140, 30)
    StartBtn.Text = "СТАРТ ТЕСТ"
end

