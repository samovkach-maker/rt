local yPos = 345
for _, testData in ipairs(tests) do
    local name = testData[1]
    local func = testData[2]
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 26)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(100, 60, 0)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 10
    btn.Parent = Frame
    
    btn.MouseButton1Click:Connect(function()
        local before = getSlaps()
        func()
        task.wait(1)
        local after = getSlaps()
        SlapsLabel.Text = "СЛАПЫ: " .. after
        if after > before then
            addOutput("✅ " .. name .. ": +" .. (after - before) .. " СЛАПОВ!")
        else
            addOutput("❌ " .. name .. ": 0 слапов")
        end
    end)
    
    yPos = yPos + 28
end

-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

