-- 8. Прямое изменение leaderstats (если разрешено на клиенте)
local function tryDirectBounty()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    if stats then
        local bounty = stats:FindFirstChild("Bounty") or stats:FindFirstChild("Score") or stats:FindFirstChild("Points")
        if bounty and bounty:IsA("IntValue") or bounty:IsA("NumberValue") then
            bounty.Value = bounty.Value + 5
            print("[DIRECT] Прямое изменение: " .. bounty.Name .. " теперь = " .. bounty.Value)
        end
    end
end
tryDirectBounty()

-- 9. Перебор всех RemoteEvent с любыми ключевыми словами (грубая сила)
local allRemotes = {}
for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        table.insert(allRemotes, obj)
    end
end

-- Пробуем отправить фейковые аргументы в каждый RemoteEvent
for _, remote in pairs(allRemotes) do
    pcall(function()
        remote:FireServer("GiveBounty", 5)
        remote:FireServer("AddPoints", 5)
        remote:FireServer("UpdateScore", 5)
