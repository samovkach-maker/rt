local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

-- Функция поиска всех RemoteEvent
local function findRemotes(keyword)
    local list = {}
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and string.find(obj.Name:lower(), keyword:lower()) then
            table.insert(list, obj)
        end
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("RemoteEvent") and string.find(obj.Name:lower(), keyword:lower()) then
            table.insert(list, obj)
        end
    end
    return list
end

-- 1. Имитация квеста (QuestReward)
local questRemotes = findRemotes("quest")
for _, remote in pairs(questRemotes) do
    remote:FireServer("CompleteQuest", "DailyKill", 5) -- или свои аргументы
    print("[QUEST] Имитация квеста через " .. remote.Name)
end

