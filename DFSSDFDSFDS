btn.MouseButton1Click:Connect(function()
    results = "=== СКАНЕР УЯЗВИМОСТЕЙ ===\n\n"
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    -- 1. Слапы напрямую
    results = results .. "--- СЛАПЫ НАПРЯМУЮ ---\n"
    test("BountyResponse", function()
        local r = findRemote("BountyResponse")
        if r then r:FireServer(100) end
    end)
    test("AddSlaps Command", function()
        local r = findRemote("Command")
        if r then r:FireServer("addslaps", 100) end
    end)
    
    -- 2. Перчатки
    results = results .. "\n--- ПЕРЧАТКИ ---\n"
    test("EquipGlove", function()
        local r = findFunction("CMDRGetGloveIDs") or findFunction("GetGloveIDs")
        if r then r:InvokeServer() end
    end)
    test("UnlockGlove", function()
        local r = findRemote("SpecialGloveAccess")
        if r then r:FireServer("All") end
    end)
    
    -- 3. Годмод
    results = results .. "\n--- ГОДМОД ---\n"
    test("SetHealth Max", function()
        if hum then hum.Health = hum.MaxHealth * 100 end
    end)
    test("Disable Damage", function()
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
    
    -- 4. Скорость
    results = results .. "\n--- СКОРОСТЬ ---\n"
    test("WalkSpeed", function()
        if hum then hum.WalkSpeed = 100 end
    end)
    test("JumpPower", function()
        if hum then hum.JumpPower = 200 end
    end)
    
    -- 5. Телепорт
    results = results .. "\n--- ТЕЛЕПОРТ ---\n"
    test("Teleport to 0,100,0", function()
        if hrp then hrp.CFrame = CFrame.new(0, 100, 0) end
    end)
    
    -- 6. Атрибуты
    results = results .. "\n--- АТРИБУТЫ ПЕРСОНАЖА ---\n"
    test("Set Bounty 0", function()
        if char then char:SetAttribute("Bounty", 0) end
    end)
    test("Set GodMode", function()
        if char then char:SetAttribute("GodMode", true) end
    end)
    
    -- 7. Прямые манипуляции
    results = results .. "\n--- ПРЯМЫЕ МАНИПУЛЯЦИИ ---\n"
    test("Destroy others", function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                p.Character:Destroy()
            end
        end
    end)
    
    output.Text = results
    setclipboard(results)
    print(results)
end)

