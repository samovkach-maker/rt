-- Функции
local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function doAbilityHit()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- GeneralAbility даёт +5
    if generalAbility then
        pcall(function() generalAbility:FireServer(hrp) end)
        pcall(function() generalAbility:FireServer(hrp.Position) end)
        pcall(function() generalAbility:FireServer() end)
    end
    
    task.wait(0.05)
    
    -- GeneralHit даёт +1 (дополнительно)
    if generalHit then
        pcall(function() generalHit:FireServer(hrp) end)
        pcall(function() generalHit:FireServer() end)
    end
    
    return true
end

local farmTask
local function startFarm()
    farming = true
    hits = 0
    totalGained = 0
    lastSlaps = getSlaps()
    
    farmTask = task.spawn(function()
        while farming do
            doAbilityHit()
            hits = hits + 1
            
            local current = getSlaps()
            if current > lastSlaps then
                totalGained = totalGained + (current - lastSlaps)
                lastSlaps = current
            end
            
            -- UI обновление каждые 5 ударов
            if hits % 5 == 0 then
                SlapsLabel.Text = "Slaps: " .. current
                StatsLabel.Text = "Ударов: " .. hits .. " | +Slaps: " .. totalGained
                local perMin = math.floor((totalGained / (hits * delayTime)) * 60)
                SpeedLabel.Text = "Задержка: " .. string.format("%.1f", delayTime) .. "с | ~" .. perMin .. "/мин"
            end
            
            task.wait(delayTime)
        end
    end)
end

local function stopFarm()
    farming = false
    if farmTask then
        task.cancel(farmTask)
        farmTask = nil
    end
    local current = getSlaps()
    SlapsLabel.Text = "Slaps: " .. current
    StatsLabel.Text = "Ударов: " .. hits .. " | +Slaps: " .. totalGained
end

