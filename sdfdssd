-- Ищем GeneralHit
local function findGeneralHit()
    -- Прямой поиск
    local gh = ReplicatedStorage:FindFirstChild("GeneralHit")
    if gh and gh:IsA("RemoteEvent") then return gh end
    
    -- Ищем везде
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == "GeneralHit" and obj:IsA("RemoteEvent") then
            return obj
        end
    end
    return nil
end

local generalHit = findGeneralHit()
if not generalHit then
    warn("GeneralHit не найден!")
end

-- Функция удара
local function doHit()
    if not generalHit then
        generalHit = findGeneralHit()
        if not generalHit then return false end
    end
    
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Ищем цель рядом
    local target = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local tHrp = player.Character:FindFirstChild("HumanoidRootPart")
            if tHrp and (tHrp.Position - hrp.Position).Magnitude < 30 then
                target = tHrp
                break
            end
        end
    end
    if not target then target = hrp end
    
    -- Отправляем хит с разными аргументами для надёжности
    pcall(function() generalHit:FireServer(target.Position) end)
    pcall(function() generalHit:FireServer(target) end)
    pcall(function() generalHit:FireServer(hrp.Position) end)
    pcall(function() generalHit:FireServer() end)
    
    return true
end

