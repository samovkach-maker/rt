    -- Авто-подбор: начинаем с 0.1 и увеличиваем пока не найдём стабильную
    delayTime = 0.1
    MethodText.Text = "Метод: GeneralHit [АВТО: ищу скорость...]"
    task.spawn(function()
        while farming and delayTime <= 1.0 do
            task.wait(2)
            delayTime = delayTime + 0.1
            updateUI()
        end
        MethodText.Text = "Метод: GeneralHit [АВТО: готово]"
    end)
end)

-- Перетаскивание
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos = false, nil, nil
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

