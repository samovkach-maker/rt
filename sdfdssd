-- Обновление Slaps
local function getSlaps()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local s = ls:FindFirstChild("Slaps")
        if s then return s.Value end
    end
    return 0
end

local function updateUI()
    SlapsLabel.Text = "Slaps: " .. getSlaps()
    HitsLabel.Text = "Ударов: " .. hits .. " | Задержка: " .. string.format("%.2f", delayTime) .. "с"
    SpeedText.Text = "Скорость: " .. string.format("%.2f", delayTime) .. "с"
end

-- Фарм цикл
local farmConnection
local function startFarm()
    farming = true
    farmConnection = RunService.Heartbeat:Connect(function(dt)
        if not farming then return end
        lastHitTime = lastHitTime + dt
        if lastHitTime >= delayTime then
            lastHitTime = 0
            doHit()
            hits = hits + 1
        end
    end)
    -- UI обновление
    task.spawn(function()
        while farming do
            updateUI()
            task.wait(0.5)
        end
    end)
end

local function stopFarm()
    farming = false
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
    updateUI()
end

ToggleBtn.MouseButton1Click:Connect(function()
    if farming then
        stopFarm()
        ToggleBtn.Text = "СТАРТ ФАРМ"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    else
        startFarm()
        ToggleBtn.Text = "СТОП ФАРМ"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
    end
end)

FasterBtn.MouseButton1Click:Connect(function()
    delayTime = math.max(0.1, delayTime - 0.05)
