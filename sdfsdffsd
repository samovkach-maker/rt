-- ЧАСТЬ 5: Исследование UnitsShowroom, ToolsShowroom, LobbyPads + поиск данных о пасах/юнитах
local Workspace = game:GetService("Workspace")
local LocalPlayer = game:GetService("Players").LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local text = ""

-- 1. UnitsShowroom
local units = Workspace:FindFirstChild("UnitsShowroom")
if units then
    text = text .. "=== UnitsShowroom ===\n"
    for _, obj in pairs(units:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            text = text .. "ProximityPrompt: " .. obj.Parent:GetFullName() .. "\n"
        end
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            text = text .. obj.ClassName .. ": " .. obj:GetFullName() .. "\n"
        end
        if obj:IsA("IntValue") or obj:IsA("StringValue") or obj:IsA("NumberValue") then
            text = text .. "Value: " .. obj.Name .. " = " .. tostring(obj.Value) .. "\n"
        end
    end
end

