-- 4. Поиск данных о пасах/юнитах/инструментах у игрока
text = text .. "\n=== ДАННЫЕ ИГРОКА ===\n"
for _, child in pairs(LocalPlayer:GetChildren()) do
    if child:IsA("Folder") and child.Name ~= "leaderstats" then
        text = text .. child.Name .. ":\n"
        for _, sub in pairs(child:GetChildren()) do
            pcall(function()
                if sub:IsA("BoolValue") or sub:IsA("IntValue") or sub:IsA("StringValue") then
                    text = text .. "  " .. sub.Name .. " = " .. tostring(sub.Value) .. "\n"
                else
                    text = text .. "  " .. sub.Name .. " [" .. sub.ClassName .. "]\n"
                end
            end)
        end
    end
end

-- 5. Вызов ключевых RemoteEvent с аргументами
text = text .. "\n=== ТЕСТ КЛЮЧЕВЫХ REMOTEEVENT ===\n"
local eventsToTest = {
    "RequestUpgrade",
    "BuyEquipSkinEvent",
    "BuyEquipSlapToolEvent",
    "RebirthRequestEvent",
    "EquipCustomTool",
    "SetCustomSpeedEvent",
}

for _, eventName in ipairs(eventsToTest) do
    local ev = nil
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj.Name == eventName and obj:IsA("RemoteEvent") then
            ev = obj
            break
        end
    end
    if ev then
        text = text .. eventName .. ":\n"
        pcall(function() ev:FireServer() end)
        pcall(function() ev:FireServer(LocalPlayer) end)
        pcall(function() ev:FireServer(1) end)
        pcall(function() ev:FireServer("buy") end)
        text = text .. "  вызовы отправлены\n"
    else
        text = text .. eventName .. ": не найден\n"
    end
end

setclipboard(text)
print(text)
print("Скопировано!")
