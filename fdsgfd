        farming = false
        btn.Text = "СТАРТ"
        btn.BackgroundColor3 = Color3.fromRGB(30, 140, 30)
        status.Text = "Остановлено"
        return
    end
    
    farming = true
    hits = 0
    btn.Text = "СТОП"
    btn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
    status.Text = "ФАРМ НА СЕБЕ"
    status.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    task.spawn(function()
        while farming do
            doHit()
            hits = hits + 1
            counter.Text = "Ударов: " .. hits
            task.wait(delayTime)
        end
    end)
end)

